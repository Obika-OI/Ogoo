{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "mobile": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web-expo": "expo start --web"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "~18.2.79",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "expo": "^51.0.0",
    "expo-speech": "^12.0.1",
    "express": "^4.21.2",
    "formidable": "^3.5.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-markdown": "^10.1.0",
    "react-native": "0.74.5",
    "react-native-web": "^0.19.10",
    "vite": "^6.2.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/formidable": "^3.5.1",
    "@types/node": "^22.14.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.3.3",
    "vite": "^6.2.3"
  }
}
